# Copie para ".env" (sem .example) e preencha. NAO commitar este arquivo com valores reais.

# --- Criptografia de credenciais (CRITICO) ---
# Chave usada pelo n8n para criptografar credenciais salvas no banco
# (database.sqlite dentro do volume hermes-data). Gere UMA VEZ com:
#   openssl rand -hex 24
# e NUNCA troque depois que ja houver credenciais salvas - trocar esta chave
# torna toda credencial existente ilegivel (erro "Credentials could not be
# decrypted") e nao ha forma de recuperar sem a chave antiga.
N8N_ENCRYPTION_KEY=troque-por-uma-chave-aleatoria-forte

# --- Timezone usado nos nodes de agendamento (Cron/Schedule Trigger) ---
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# --- Endereco/porta que o n8n anuncia para si mesmo (webhooks, links de e-mail) ---
# Usa o hostname registrado (ver scripts/add-hosts-entries.ps1 e -Hostname em
# setup-hermes-wslc.ps1) em vez de localhost/127.0.0.1, para o endereco ficar
# estavel e identico ao usado por outros containers na -SharedNetwork. Se
# customizar -Hostname no setup, atualize aqui tambem (o script avisa, mas
# nao sobrescreve sozinho).
N8N_HOST=hermes-n8n
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://hermes-n8n:5678/

# --- Cookie de sessao ---
# false = necessario para acessar via http://hermes-n8n (sem TLS). Se algum
# dia colocar um reverse proxy com HTTPS na frente, troque para true.
N8N_SECURE_COOKIE=false
